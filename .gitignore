# Áudios (grandes, não versionados)
*.mp3
*.m4a
*.wav

# Saída bruta de conversão de epub e downloads (regeneráveis via scripts)
# Padrões category-agnostic (**) — robustos à reorg projetos/<categoria>/<projeto>
projetos/**/_raw/
projetos/**/obras/**/clean/
projetos/**/obras/**/capitulos/
projetos/**/obras/**/cenas/
projetos/**/obras/**/prompts/

# Exceção: versionar o ESTADO de áudio do aristoteles (status created->downloaded),
# análogo ao metadata.json dos outros projetos. O resto do _raw/ segue ignorado.
# (precisa re-incluir o dir antes do arquivo — git não recursa em dir ignorado.)
!projetos/filosofia/aristoteles/_raw/
projetos/filosofia/aristoteles/_raw/*
!projetos/filosofia/aristoteles/_raw/audio_metadata.json

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.env

# Dolt database files (added by bd init)
.dolt/
*.db

# Notre-Dame Formative Reading Original Texts
projetos/**/notre-dame_de_paris/Notre-Dame_de_Paris.md
projetos/**/notre-dame_de_paris/cenas/

# Manzoni Formative Reading
projetos/**/I Promesi Sposi/cenas/

# Áudios baixados do NotebookLM (pesados, mantidos só localmente)
**/audios/*.m4a
**/audios/*.mp3

# Symlinks de compatibilidade do crontab (bridge nomes antigos -> categorias).
# Só existem no StudioM4; permitem o crontab atual achar os cron_*.sh sem editá-lo.
# Recriáveis via logs/fix_symlinks.sh. NÃO apagar sem antes editar o crontab.
/projetos/aristoteles
/projetos/cof_v2
/projetos/mazoni
/projetos/victor_hugo

# Crítica literária: epubs/PDFs ficam no DROBO; áudios são pesados.
projetos/critica-literaria/**/source/
projetos/critica-literaria/**/audios/*.m4a
projetos/critica-literaria/**/output/images/

